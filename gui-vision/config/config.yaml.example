api:
  api_key: "your-qwen-api-key"
  base_url: "https://coding.dashscope.aliyuncs.com/v1"
  model: "qwen3.5-plus"

screen:
  width: 1920
  height: 1080

safety:
  auto_confirm_low_risk: true
  require_confirmation:
    - delete
    - close
    - shutdown
    - format

timing:
  action_delay: 0.5
  screenshot_delay: 1.0
  max_wait_time: 10.0

agent:
  max_steps: 50
  max_retries: 3

# 系统提示词配置 - 告诉视觉模型你的系统环境
system_prompt:
  enabled: true
  os: "Linux"
  desktop: "KDE Plasma"
  language: "zh_CN"
  custom_shortcuts:
    show_desktop: "win+d"
    open_terminal: "ctrl+alt+t"
    switch_window: "alt+tab"
    close_window: "alt+f4"
    open_file_manager: "win+e"
  custom_instructions: |
    - 任务栏在屏幕底部
    - 常用应用：Dolphin(文件管理器)、Konsole(终端)、Chrome(浏览器)
    - 双击打开文件，右键显示上下文菜单